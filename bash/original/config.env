# Pipeline Manager Configuration
# Generated by setup script

# ============================================================================
# Deployment Settings
# ============================================================================
DEPLOY_SERVER="deploy.example.com"
DEPLOY_PORT="22"
DEPLOY_USER="deployer"
DEPLOY_KEY="~/.ssh/deploy_key"
DEPLOY_AUTH_METHOD="key"

# ============================================================================
# Database
# ============================================================================
DATABASE_URL="sqlite:///data/pipeline.db"
REDIS_URL="redis://localhost:6379/0"

# ============================================================================
# API Configuration
# ============================================================================
API_ENDPOINT="https://api.example.com"
API_TOKEN=""

# ============================================================================
# Webhooks
# ============================================================================
WEBHOOK_SECRET=""
CI_ENDPOINT="http://localhost:8080/api/build"

# ============================================================================
# Notifications
# ============================================================================
SLACK_WEBHOOK=""

# ============================================================================
# Environments
# ============================================================================
ENVIRONMENTS="development,staging,production"
AUTO_DEPLOY_BRANCHES="main,master"

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_RETENTION_DAYS="30"
BACKUP_ENCRYPTION_KEY=""

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL="INFO"

# ============================================================================
# Development Mode Flags (DO NOT USE IN PRODUCTION)
# ============================================================================
DEPLOY_SKIP_HOST_CHECK="false"

# ============================================================================
# Environment-Specific Overrides
# ============================================================================
# PRODUCTION_DEPLOY_SERVER="prod.example.com"
# STAGING_DEPLOY_SERVER="staging.example.com"
